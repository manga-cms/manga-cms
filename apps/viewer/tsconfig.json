{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "baseUrl": ".",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@manga/domain": [
                "../../packages/domain/src/index.ts"
            ],
            "@manga/domain/*": [
                "../../packages/domain/src/*"
            ]
        }
    }
}
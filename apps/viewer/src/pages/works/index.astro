---
import BaseLayout from "../../layouts/BaseLayout.astro";
import OfficialPage from "../../components/site/OfficialPage.astro";
import {
  getViewerSeriesCards,
  latestEpisode,
  lifecycleStatusLabel,
  primarySeriesActionLabel,
  primarySeriesHref,
  publicationTypeLabel,
} from "../../lib/series-cards";
import { isOfficialSite } from "../../lib/site-config";

const series = isOfficialSite ? [] : await getViewerSeriesCards();
---

{isOfficialSite ? (
  <OfficialPage
    title="Works"
    description="manga-cms.com official mode does not use /works as the primary surface"
    eyebrow="serial site route"
    intro="公式サイトモードでは /works を主導線にしません。公開許諾済みの作品がある場合は、公式トップから直接Readerへ案内します。"
    actions={[{ label: "公式トップへ", href: "/" }]}
    sections={[
      {
        eyebrow: "Boundary",
        title: "creator-run serial site のための route です",
        body: "Serial mode では従来通り /works、作品詳細、Reader routes を使います。Official mode では public-safe demo が確定するまでローカル fixtures を表示しません。",
      },
    ]}
  />
) : (
  <BaseLayout title="作品 — Manga Viewer" description="Manga Viewer で公開中の作品一覧">
    <section class="container page-section">
      <div class="page-heading">
        <p class="page-kicker">Works</p>
        <h1>作品一覧</h1>
        <p class="text-muted page-desc">読みたい作品を選んでください。公開中のエピソードへすぐ進めます。</p>
      </div>

      {series.length > 0 ? (
        <div class="work-list">
          {series.map((s) => {
            const latest = latestEpisode(s.episodes);
            const primaryHref = primarySeriesHref(s);
            const primaryLabel = primarySeriesActionLabel(s);
            return (
              <article class="work-row">
                <a href={primaryHref} class="work-cover-link" aria-label={`${s.title} ${primaryLabel}`}>
                  <figure class="work-cover-frame">
                    {s.coverUrl ? (
                      <img src={s.coverUrl} alt="" class="work-cover" onerror="this.nextElementSibling.hidden=false;this.remove()" />
                    ) : null}
                    <span class="cover-fallback" hidden={Boolean(s.coverUrl)}>{s.title.slice(0, 1)}</span>
                  </figure>
                </a>
                <div class="work-main">
                  <div class="work-heading">
                    <div>
                      <h2><a href={primaryHref}>{s.title}</a></h2>
                      <p class="work-description">{s.description || "作品情報を準備中です。"}</p>
                    </div>
                    <div class="work-title-badges">
                      <span class="badge">{publicationTypeLabel(s.publicationType)}</span>
                      <span class="badge">{lifecycleStatusLabel(s.lifecycleStatus ?? s.status)}</span>
                    </div>
                  </div>
                  <div class="work-footer">
                    <span>{s.episodes.length} 話</span>
                    {latest ? (
                      <span>最新: 第{latest.episodeNumber}話</span>
                    ) : (
                      <span>公開準備中</span>
                    )}
                    <span class="work-actions">
                      <a href={primaryHref}>{primaryLabel}</a>
                      {latest && primaryHref !== `/works/${s.id}/episodes/${latest.id}` && (
                        <a href={`/works/${s.id}/episodes/${latest.id}`}>最新話を読む</a>
                      )}
                    </span>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <div class="empty-state">
          <p class="empty-title">公開中の作品はまだありません。</p>
          <p class="text-muted">contents が空の場合も、作品が追加されるまでこの表示で案内します。</p>
        </div>
      )}
    </section>
  </BaseLayout>
)}

<style>
  .page-section {
    padding-block: clamp(2.75rem, 6vw, 4.5rem);
  }

  .page-heading {
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
  }

  .page-kicker {
    color: var(--color-text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-bottom: 0.65rem;
    text-transform: uppercase;
  }

  .page-heading h1 {
    font-size: clamp(1.75rem, 4vw, 2.6rem);
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .page-desc {
    max-width: 38rem;
  }

  .work-list {
    display: grid;
    gap: 0.8rem;
  }

  .work-row {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    display: grid;
    gap: 1rem;
    grid-template-columns: 96px minmax(0, 1fr);
    padding: 0.9rem;
  }

  .work-cover-link {
    color: inherit;
  }

  .work-cover-frame {
    align-items: center;
    aspect-ratio: 2 / 3;
    background: #f4f4f1;
    border: 1px solid var(--color-border);
    display: flex;
    justify-content: center;
    margin: 0;
    overflow: hidden;
    width: 96px;
  }

  .work-cover {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .cover-fallback {
    color: var(--color-text-muted);
    font-size: 1.75rem;
    font-weight: 700;
  }

  .work-main {
    display: grid;
    gap: 0.8rem;
    min-width: 0;
  }

  .work-heading {
    align-items: start;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
  }

  .work-title-badges {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    justify-content: flex-end;
  }

  .work-heading h2 {
    font-size: 1.05rem;
    line-height: 1.45;
    margin-bottom: 0.35rem;
  }

  .work-heading h2 a {
    color: var(--color-text);
  }

  .work-description {
    color: var(--color-text-muted);
    font-size: 0.86rem;
    line-height: 1.8;
    max-width: 42rem;
  }

  .work-footer {
    align-items: center;
    color: var(--color-text-muted);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.8rem;
    gap: 0.8rem;
  }

  .work-actions {
    display: inline-flex;
    gap: 0.8rem;
    margin-left: auto;
  }

  .work-actions a {
    color: var(--color-text);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: var(--color-border);
    text-underline-offset: 0.25em;
  }

  .work-actions a:hover {
    color: var(--color-accent);
    text-decoration-color: currentColor;
  }

  .empty-state {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: clamp(2rem, 6vw, 3rem);
  }

  .empty-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  @media (max-width: 640px) {
    .work-row {
      grid-template-columns: 82px minmax(0, 1fr);
    }

    .work-cover-frame {
      width: 82px;
    }

    .work-heading {
      display: grid;
      gap: 0.55rem;
    }

    .work-actions {
      margin-left: 0;
      width: 100%;
    }
  }
</style>

---
/**
 * Episode reader page (SSR).
 *
 * Data path:
 *   1. If API_BASE is set → fetch from @manga/api (primary)
 *   2. If API_BASE is not set → fall back to shared content loader
 *
 * Entitlement gating:
 *   - API returns `gated: true` for locked episodes without entitlement
 *   - Viewer shows preview + unlock CTA for gated content
 *   - Ungated content uses delivery URLs (not raw image paths)
 */
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { fetchEpisode, isApiConfigured } from "../../../../lib/api-client";
import { getSeries, getEpisode, getAdjacentEpisodes } from "../../../../data/content";

// SSR — not prerendered. Required for entitlement gating.
export const prerender = false;

const { workId, episodeId } = Astro.params;

if (!workId || !episodeId) {
  return Astro.redirect("/works");
}

// --- Data resolution: API-first with loader fallback ---
let seriesTitle = "";
let episode: { title: string; episodeNumber: number; publishedAt: string; pages: any[] } | null = null;
let seriesCoverUrl = "";
let seriesShareImageUrl = "";
let prev: { id: string; title: string; episodeNumber: number } | null = null;
let next: { id: string; title: string; episodeNumber: number } | null = null;
let dataSource: "api" | "loader" | "none" = "none";
let isGated = false;
let gatedMessage = "";
let isUnavailable = false;
let unavailableMessage = "";
let apiError = "";

// Forward request cookies for SSR auth propagation
const requestCookies = Astro.request.headers.get("cookie") ?? undefined;

const apiConfigured = isApiConfigured();

if (apiConfigured) {
  const result = await fetchEpisode(workId, episodeId, requestCookies);
  if (result.data) {
    seriesTitle = result.data.series.title;
    seriesCoverUrl = result.data.series.coverUrl ?? "";
    seriesShareImageUrl = result.data.series.shareImageUrl ?? "";
    episode = result.data.episode;
    prev = result.data.prev;
    next = result.data.next;
    dataSource = "api";
    // Check for gated response from API
    if ((result.data as any).gated === true) {
      isGated = true;
      gatedMessage = (result.data as any).message ?? "このエピソードを読むには購入が必要です";
    }
  } else {
    apiError = result.error ?? "API request failed";
  }
}

// Fallback to shared content loader (ONLY for free episodes)
if (!episode && !apiConfigured) {
  const work = getSeries(workId);
  const ep = getEpisode(workId, episodeId);
  if (work && ep) {
    seriesTitle = work.title;
    seriesCoverUrl = work.coverUrl;
    seriesShareImageUrl = work.shareImageUrl ?? "";
    // For loader fallback, only show ep1 (free). Others are gated.
    if (ep.episodeNumber <= 1) {
      episode = ep;
      const adj = getAdjacentEpisodes(workId, episodeId);
      prev = adj.prev ? { id: adj.prev.id, title: adj.prev.title, episodeNumber: adj.prev.episodeNumber } : null;
      next = adj.next ? { id: adj.next.id, title: adj.next.title, episodeNumber: adj.next.episodeNumber } : null;
      dataSource = "loader";
    } else {
      // Locked in fallback mode
      episode = { title: ep.title, episodeNumber: ep.episodeNumber, publishedAt: ep.publishedAt, pages: [] };
      isGated = true;
      gatedMessage = "このエピソードを読むにはログインと購入が必要です";
      dataSource = "loader";
    }
  }
}

if (!episode && apiConfigured) {
  const fallbackSeriesForUnavailable = getSeries(workId);
  seriesTitle ||= fallbackSeriesForUnavailable?.title ?? workId;
  seriesCoverUrl ||= fallbackSeriesForUnavailable?.coverUrl ?? "";
  seriesShareImageUrl ||= fallbackSeriesForUnavailable?.shareImageUrl ?? "";
  episode = {
    title: "現在公開されていません",
    episodeNumber: 0,
    publishedAt: "",
    pages: [],
  };
  isUnavailable = true;
  unavailableMessage = apiError.startsWith("404")
    ? "このエピソードは現在公開されていないか、存在しません。"
    : "APIからエピソードを取得できませんでした。時間をおいて再度お試しください。";
  dataSource = "api";
}

// Check first page for gated flag (API response)
if (episode && !isGated && dataSource === "api") {
  // We need to check a page endpoint to see if it's gated
  // For now, we rely on the episode metadata being available
  // The actual gating happens when rendering pages
}

if (!episode) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const isSafeReaderImageSrc = (src: unknown): src is string => {
  if (typeof src !== "string" || src.length === 0) return false;
  if (src === "/placeholder-page.svg") return true;
  if (src.startsWith("/api/v1/deliver/") || src.startsWith("/deliver/")) return true;
  try {
    const url = new URL(src);
    if (url.protocol !== "http:" && url.protocol !== "https:") return false;
    if (url.pathname.includes("/contents/")) return false;
    if (/\/pages\/[^/]+\.(jpe?g|png|webp|gif)$/i.test(url.pathname)) return false;
    return true;
  } catch {
    return false;
  }
};

const resolveReaderImageSrc = (page: any) => {
  const preferred = page.images?.ja;
  return isSafeReaderImageSrc(preferred) ? preferred : "/placeholder-page.svg";
};

const viewerPages = episode.pages.map((page: any) => ({
  id: page.id,
  pageNumber: page.pageNumber,
  displayRef: page.displayRef,
  src: resolveReaderImageSrc(page),
  width: page.width,
  height: page.height,
  availablePacks: page.availablePacks ?? [],
  panels: (page.panels ?? []).map((panel: any) => ({
    id: panel.id,
    panelNumber: panel.panelNumber,
    bbox: panel.bbox,
    feedbackEnabled: panel.flags?.feedback_enabled !== false,
    shareable: panel.flags?.shareable !== false,
    bubbles: (panel.bubbles ?? []).map((bubble: any) => ({
      id: bubble.id,
      bubbleNumber: bubble.bubbleNumber,
      shortId: bubble.shortId,
      bubbleType: bubble.bubbleType,
      textOriginal: bubble.textOriginal,
      speaker: bubble.speaker,
      bbox: bubble.bbox,
      feedbackEnabled: bubble.flags?.feedback_enabled !== false,
      shareable: bubble.flags?.shareable !== false,
    })),
  })),
}));
const fallbackSeries = getSeries(workId);
seriesCoverUrl ||= fallbackSeries?.coverUrl ?? "";
seriesShareImageUrl ||= fallbackSeries?.shareImageUrl ?? "";
const viewerPagesJson = JSON.stringify(viewerPages).replace(/</g, "\\u003c");
const feedbackApiBase = (import.meta.env.API_BASE ?? "").replace(/\/$/, "") || "/api/v1";
const feedbackApiBaseJson = JSON.stringify(feedbackApiBase).replace(/</g, "\\u003c");
const isReaderAvailable = !isGated && episode.pages.length > 0;
const episodeDescription = `${seriesTitle} Episode ${episode.episodeNumber}: ${episode.title}`;
const hasPublicCoverUrl = seriesCoverUrl.startsWith("/") || /^https?:\/\//.test(seriesCoverUrl);
const hasPublicShareImageUrl = seriesShareImageUrl.startsWith("/") || /^https?:\/\//.test(seriesShareImageUrl);
const episodeOgImage = hasPublicShareImageUrl
  ? seriesShareImageUrl
  : hasPublicCoverUrl
    ? seriesCoverUrl
    : viewerPages[0]?.src || "/placeholder-cover.svg";
---

<BaseLayout
  title={`${episode.title} — ${seriesTitle}`}
  description={episodeDescription}
  ogImage={episodeOgImage}
  ogType="article"
  immersive
>
  <section class:list={["container", "page-section", { "is-reader-page": isReaderAvailable }]}>
    {!isReaderAvailable && (
      <>
        <a href={`/works/${workId}`} class="breadcrumb text-muted">
          ← {seriesTitle}
        </a>

        {!isUnavailable && (
          <div class="episode-header">
            <span class="ep-number badge">Episode {episode.episodeNumber}</span>
            <h1>{episode.title}</h1>
            <p class="text-muted">{episode.publishedAt}</p>
            {import.meta.env.DEV && dataSource === "loader" && !isGated && (
              <p class="data-source-hint text-muted">⚠ API未接続 — ローカルデータ表示中（開発モード）</p>
            )}
          </div>
        )}
      </>
    )}

    {isUnavailable ? (
      <div class="placeholder-reader card">
        <h1>このエピソードは現在公開されていません</h1>
        <p class="text-muted">{unavailableMessage}</p>
        <div class="gated-actions">
          <a href={`/works/${workId}`} class="btn-viewer btn-primary-viewer">作品ページに戻る</a>
        </div>
      </div>
    ) : isGated ? (
      <div class="gated-overlay card">
        <div class="gated-icon">🔒</div>
        <h2>このエピソードはロックされています</h2>
        <p class="text-muted">{gatedMessage || "このエピソードを読むには購入が必要です"}</p>
        <div class="gated-actions">
          <a href="/works" class="btn-viewer btn-primary-viewer">作品一覧に戻る</a>
        </div>
      </div>
    ) : episode.pages.length === 0 ? (
      <div class="placeholder-reader card">
        <p class="text-muted">このエピソードのページはまだありません。</p>
      </div>
    ) : (
      <div class="reader-shell" data-work-id={workId} data-episode-id={episodeId}>
        <div class="reader-toolbar" aria-label="Reader controls">
          <div class="reader-meta">
            <a href={`/works/${workId}`} class="reader-back">← {seriesTitle}</a>
            <span>{episode.title}</span>
          </div>
          <div class="reader-mode">
            <button type="button" class="reader-mode-button is-active" data-mode-button="normal">Read</button>
            <button type="button" class="reader-mode-button" data-mode-button="explore">Explore / くわしく見る</button>
          </div>
          <div class="reader-progress">
            <span data-current-page>1</span> / {episode.pages.length}
          </div>
          <p class="reader-hint text-muted">スワイプ・左右キー・画面左右タップでページ送り</p>
        </div>

        <div class="reader-stage" data-reader-stage>
          <button type="button" class="reader-nav-zone reader-nav-next" data-reader-next aria-label="次のページへ">←</button>
          <div class="reader-viewport" id="reader" tabindex="0" aria-label="Manga reader">
            <div class="reader-track" data-reader-track></div>
          </div>
          <button type="button" class="reader-nav-zone reader-nav-prev" data-reader-prev aria-label="前のページへ">→</button>
        </div>

        <aside class="study-panel" data-study-panel>
          <div>
            <p class="study-panel-kicker">Explore / Feedback</p>
            <h2 data-explore-title>Page <span data-note-page>1</span></h2>
            <p class="text-muted" data-explore-summary>フキダシやコマを選ぶと、原文確認や軽い提案ができます。本格レビューとPack反映はCMS側で扱います。</p>
          </div>
          <div class="explore-detail" data-explore-detail>
            <p class="text-muted">Explore Modeでページ内のフキダシ/コマを選択してください。</p>
          </div>
          <label>
            <span>脚注・翻訳メモ</span>
            <textarea
              data-note-input
              rows="5"
              placeholder="例: このセリフはPackの説明で補足したい、翻訳では別案がありそう、など"
            ></textarea>
          </label>
          <div class="study-target-grid">
            <label>
              <span>対象</span>
              <select data-note-scope>
                <option value="page">ページ全体</option>
                <option value="panel">コマ</option>
                <option value="bubble">フキダシ</option>
                <option value="region">任意位置</option>
              </select>
            </label>
            <label>
              <span>対象メモ</span>
              <input data-note-target placeholder="例: 右上のフキダシ / 2コマ目 / 画面中央" />
            </label>
          </div>
          <p class="text-muted study-panel-note" data-note-anchor>位置指定なし。Explore Modeでページ画像をクリックすると、注の位置候補を保存できます。</p>
          <p class="text-muted study-panel-note">Readerでは軽い報告/提案だけを受け付けます。正式編集はCMSで行います。</p>
        </aside>
        <script type="application/json" id="reader-pages" set:html={viewerPagesJson}></script>
        <script type="application/json" id="feedback-api-base" set:html={feedbackApiBaseJson}></script>
        <div class="reader-context-menu" data-reader-context-menu hidden></div>
        <div class="reader-toast" data-reader-toast hidden></div>
        <div class="feedback-modal" data-feedback-modal hidden>
          <div class="feedback-modal-backdrop" data-feedback-close></div>
          <form class="feedback-dialog" data-feedback-form>
            <input type="text" name="website" autocomplete="off" tabindex="-1" class="feedback-honeypot" aria-hidden="true" />
            <div>
              <p class="study-panel-kicker" data-feedback-kicker>Feedback</p>
              <h2 data-feedback-title>報告する</h2>
              <p class="text-muted" data-feedback-target>対象を選択中</p>
            </div>
            <label>
              <span>種類</span>
              <select name="issue_type" data-feedback-issue>
                <option value="typo">誤字</option>
                <option value="mistranslation">誤訳</option>
                <option value="display">表示崩れ</option>
                <option value="better_translation">よりよい訳</option>
                <option value="missing_note">注釈提案</option>
                <option value="other">その他</option>
              </select>
            </label>
            <label>
              <span>コメント</span>
              <textarea name="comment" data-feedback-comment maxlength="1000" rows="4" placeholder="気づいた点を短く書いてください"></textarea>
            </label>
            <label data-feedback-suggested-wrap hidden>
              <span>提案文</span>
              <textarea name="suggested_text" data-feedback-suggested maxlength="2000" rows="3" placeholder="翻訳案や注釈案があれば入力してください"></textarea>
            </label>
            <div class="feedback-actions">
              <button type="button" class="btn-viewer btn-ghost-viewer" data-feedback-close>閉じる</button>
              <button type="submit" class="btn-viewer btn-primary-viewer">送信</button>
            </div>
          </form>
        </div>
      </div>
    )}

    {!isReaderAvailable && (
      <div class="episode-nav">
        {prev && (
          <a href={`/works/${workId}/episodes/${prev.id}`} class="nav-link">
            ← {prev.title}
          </a>
        )}
        <div class="spacer" />
        {next && (
          <a href={`/works/${workId}/episodes/${next.id}`} class="nav-link">
            {next.title} →
          </a>
        )}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .page-section {
    padding: var(--space-xl) 0;
  }

  .page-section.is-reader-page {
    max-width: none;
    padding: 0;
  }

  .breadcrumb {
    display: inline-block;
    font-size: 0.8125rem;
    margin-bottom: var(--space-lg);
  }

  .episode-header {
    margin-bottom: var(--space-xl);
  }

  .episode-header .ep-number {
    margin-bottom: var(--space-sm);
  }

  .episode-header h1 {
    font-size: 1.5rem;
    margin-top: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .data-source-hint {
    font-size: 0.75rem;
    margin-top: var(--space-sm);
  }

  .placeholder-reader {
    text-align: center;
    padding: var(--space-2xl);
  }

  .reader-shell {
    background: #0b0d12;
    border: 0;
    border-radius: 0;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    position: relative;
    scroll-margin-top: 0;
  }

  .reader-toolbar {
    position: sticky;
    top: 0;
    z-index: 5;
    display: grid;
    align-items: center;
    grid-template-columns: minmax(0, 1fr) auto auto minmax(0, 1fr);
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: rgba(11, 13, 18, 0.92);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(12px);
  }

  .reader-meta {
    align-items: center;
    color: var(--color-text-muted);
    display: flex;
    gap: 0.65rem;
    min-width: 0;
    white-space: nowrap;
  }

  .reader-meta span {
    color: var(--color-text);
    font-size: 0.75rem;
    font-weight: 700;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .reader-back {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-weight: 800;
  }

  .reader-back:hover,
  .reader-back:focus-visible {
    color: var(--color-text);
  }

  .reader-mode {
    display: inline-flex;
    gap: 6px;
  }

  .reader-mode-button {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 6px 12px;
  }

  .reader-mode-button.is-active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  .reader-progress {
    color: var(--color-text);
    font-size: 0.8125rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .reader-hint {
    justify-self: end;
    font-size: 0.6875rem;
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .reader-stage {
    background: #050609;
    height: 100%;
    min-height: 0;
    overflow: hidden;
    position: relative;
  }

  .reader-viewport {
    height: 100%;
    outline: none;
    overflow: hidden;
    position: relative;
    touch-action: pan-y;
    user-select: none;
  }

  .reader-track {
    display: flex;
    flex-direction: row-reverse;
    height: 100%;
    transform: translate3d(0, 0, 0);
    transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .manga-view {
    align-items: center;
    display: flex;
    flex: 0 0 100%;
    gap: 0;
    height: 100%;
    justify-content: center;
    padding: 0;
  }

  .manga-view.is-single.is-right {
    justify-content: center;
    padding-right: 0;
  }

  .manga-view.is-end {
    color: var(--color-text);
    flex-direction: column;
    text-align: center;
  }

  .reader-end-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    max-width: 520px;
    padding: var(--space-xl);
  }

  .reader-nav-zone {
    align-items: center;
    background: transparent;
    border: 0;
    bottom: 0;
    color: rgba(255, 255, 255, 0.75);
    cursor: pointer;
    display: flex;
    font-size: 1.45rem;
    font-weight: 900;
    justify-content: center;
    opacity: 0;
    position: absolute;
    top: 0;
    transition: opacity 0.2s ease;
    width: clamp(40px, 7vw, 72px);
    z-index: 4;
  }

  .reader-stage:hover .reader-nav-zone,
  .reader-nav-zone:focus-visible {
    opacity: 1;
  }

  .reader-nav-next {
    left: 0;
  }

  .reader-nav-prev {
    right: 0;
  }

  .page-frame {
    background: transparent;
    border: 0;
    border-radius: 0;
    display: flex;
    flex: 0 1 auto;
    flex-direction: row;
    height: 100%;
    justify-content: center;
    max-height: 100%;
    max-width: 50%;
    overflow: visible;
    position: relative;
    transition: max-width 0.4s ease;
  }

  .manga-view.is-single .page-frame {
    max-width: 100%;
  }

  .page-frame.highlight {
    border-color: var(--color-accent, #60a5fa);
    outline: 2px solid rgba(96, 165, 250, 0.7);
    outline-offset: -2px;
  }

  .page-frame.zoomed {
    max-width: 100%;
    cursor: zoom-out;
  }

  .page-image-wrap {
    align-items: center;
    cursor: zoom-in;
    display: flex;
    flex: 1;
    height: 100%;
    justify-content: center;
    min-height: 0;
    position: relative;
    width: 100%;
  }

  .page-frame.zoomed .page-image-wrap {
    cursor: zoom-out;
  }

  .page-frame img {
    width: auto;
    max-width: 100%;
    max-height: 100%;
    height: auto;
    display: block;
    box-shadow: none;
    filter: none;
    object-fit: contain;
  }

  .panel-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    padding: var(--space-xs) var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .panel-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-bg, #1a1a2e);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }

  .panel-badge:hover {
    color: var(--color-accent, #60a5fa);
    border-color: var(--color-accent, #60a5fa);
  }

  .bubble-count {
    font-size: 0.625rem;
  }

  .page-info {
    display: none;
    padding: var(--space-sm) var(--space-md);
    font-size: 0.75rem;
    text-align: center;
  }

  .study-panel {
    display: none;
    align-content: start;
    border: 1px solid var(--color-border);
    bottom: 16px;
    gap: var(--space-md);
    grid-template-columns: 1fr;
    overflow-x: hidden;
    overflow-y: auto;
    padding: var(--space-md);
    position: absolute;
    right: 16px;
    top: calc(49px + 16px);
    width: min(420px, calc(100vw - 32px));
    z-index: 8;
    background:
      radial-gradient(circle at 16% 16%, rgba(250, 204, 21, 0.12), transparent 26%),
      rgba(11, 13, 18, 0.96);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.42);
  }

  .reader-shell[data-mode="explore"] .study-panel {
    display: grid;
  }

  .study-panel-kicker {
    color: var(--color-primary);
    font-size: 0.6875rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin: 0 0 6px;
    text-transform: uppercase;
  }

  .study-panel h2 {
    font-size: 1rem;
    margin: 0 0 8px;
  }

  .study-panel label {
    display: grid;
    gap: 8px;
    min-width: 0;
  }

  .study-panel span {
    color: var(--color-text);
    font-size: 0.75rem;
    font-weight: 800;
  }

  .study-panel textarea {
    width: 100%;
    resize: none;
    border: 1px solid var(--color-border);
    border-radius: 0;
    background: var(--color-bg);
    color: var(--color-text);
    font: inherit;
    padding: 10px;
  }

  .study-target-grid {
    display: grid;
    gap: var(--space-sm);
    grid-template-columns: 1fr;
    min-width: 0;

---
import { robotsForLocale } from "../../lib/search-indexing";
import { resolveShareRoute, type ShareLocale } from "../../lib/share-url-metadata";

export const prerender = false;

const rawShare = Astro.params.share;
if (!rawShare) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const parts = rawShare.split("/").map((part) => decodeURIComponent(part)).filter(Boolean);
const [seriesId, episodeId] = parts;

const parseShareRoute = () => {
  if (!seriesId || !episodeId) return null;
  if (parts.length === 2) return { seriesId, episodeId };

  if (parts.length === 4 && parts[2] === "p") {
    const pageNumber = Number(parts[3]);
    if (!Number.isInteger(pageNumber) || pageNumber < 1) return null;
    return { seriesId, episodeId, pageNumber };
  }

  if (parts.length === 6 && parts[2] === "p") {
    const pageNumber = Number(parts[3]);
    if (!Number.isInteger(pageNumber) || pageNumber < 1) return null;
    if (parts[4] === "k") return { seriesId, episodeId, pageNumber, panelRef: parts[5] };
    if (parts[4] === "f") return { seriesId, episodeId, pageNumber, bubbleRef: parts[5] };
  }

  return null;
};

const parsed = parseShareRoute();
if (!parsed) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const locale: ShareLocale = Astro.url.searchParams.get("lang") === "en" ? "en" : "ja";
const siteOrigin = import.meta.env.SITE_ORIGIN as string | undefined;
const origin = siteOrigin ? new URL(siteOrigin).origin : new URL(Astro.request.url).origin;
const resolved = await resolveShareRoute({ ...parsed, locale, origin });

if (!resolved) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const alternateUrls = [
  { locale: "ja", href: resolved.canonicalUrl },
  { locale: "en", href: resolved.englishUrl },
  { locale: "x-default", href: resolved.canonicalUrl },
];

const readerUrlJson = JSON.stringify(resolved.readerUrl).replace(/</g, "\\u003c");
const refreshContent = `0;url=${resolved.readerUrl}`;
const ogLocale = locale === "ja" ? "ja_JP" : "en_US";
const robots = robotsForLocale(locale);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={resolved.description} />
    {robots && <meta name="robots" content={robots} />}
    {resolved.authorLabel && <meta name="author" content={resolved.authorLabel} />}
    <title>{resolved.title}</title>

    <meta property="og:title" content={resolved.title} />
    <meta property="og:description" content={resolved.description} />
    <meta property="og:url" content={resolved.canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:type" content="article" />
    {resolved.authorLabel && <meta property="article:author" content={resolved.authorLabel} />}
    {resolved.ogImageUrl && <meta property="og:image" content={resolved.ogImageUrl} />}
    {resolved.ogImageWidth && <meta property="og:image:width" content={String(resolved.ogImageWidth)} />}
    {resolved.ogImageHeight && <meta property="og:image:height" content={String(resolved.ogImageHeight)} />}
    {resolved.ogImageAlt && <meta property="og:image:alt" content={resolved.ogImageAlt} />}
    <meta name="twitter:card" content={resolved.ogImageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={resolved.title} />
    <meta name="twitter:description" content={resolved.description} />
    {resolved.ogImageUrl && <meta name="twitter:image" content={resolved.ogImageUrl} />}
    {resolved.ogImageAlt && <meta name="twitter:image:alt" content={resolved.ogImageAlt} />}
    <link rel="canonical" href={resolved.canonicalUrl} />
    {alternateUrls.map((alternate) => (
      <link rel="alternate" hreflang={alternate.locale} href={alternate.href} />
    ))}

    <meta http-equiv="refresh" content={refreshContent} />
    <script is:inline define:vars={{ readerUrlJson }}>
      window.location.replace(JSON.parse(readerUrlJson));
    </script>
  </head>
  <body>
    <noscript>
      <a href={resolved.readerUrl}>Readerで開く</a>
    </noscript>
  </body>
</html>

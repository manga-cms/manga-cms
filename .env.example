# ===========================================================================
# manga-cms environment variables
# ===========================================================================
# Copy to .env and adjust values for your environment.
# Required vars are marked with [REQUIRED], rest have sensible defaults.

# --- Runtime ---
NODE_ENV=development          # development | production
PORT=3000                     # API server port

# --- Content ---
CONTENTS_DIR=                 # Default: ./contents (relative to API)
PACKS_DIR=                    # Default: ./packs (canonical pack manifests)
ENTITLEMENTS_DIR=             # Default: ./entitlements (file-backed fallback)
FEEDBACK_DIR=                 # Default: ./feedback (private reader feedback JSONL)
PROPOSALS_DIR=                # Default: ./proposals (private proposal queue JSONL)
PACK_DRAFTS_DIR=              # Default: ./pack-drafts (private pack draft JSONL)

# --- Database ---
# [REQUIRED for DB mode] Set to use Prisma-backed repositories.
# SQLite example: file:./dev.db
# PostgreSQL example: postgresql://user:pass@host:5432/mangacms
DATABASE_URL=

# --- Auth ---
# Secret for HMAC-signed auth tokens. MUST be set in production.
DEV_AUTH_SECRET=
# Comma-separated user IDs that get admin role on dev-login.
DEV_ADMIN_IDS=dev-admin
# Set to 1 when behind a trusted reverse proxy (Cloudflare, nginx, etc.)
# to use X-Forwarded-For for client IP. Without this, IP-based rate limiting
# and audit logging will use a fixed "direct" value.
TRUST_PROXY=

# --- CORS ---
# Comma-separated list of allowed origins for cross-origin requests.
# If unset, all origins are allowed (suitable for development).
# Example: ALLOWED_ORIGINS=https://manga.example.com,http://localhost:4321
ALLOWED_ORIGINS=

# --- Delivery ---
# Secret for HMAC-signed delivery tokens. MUST be set in production.
DELIVERY_SECRET=
# Optional public API origin for generated delivery image URLs.
# Example: https://api.manga.example.com
DELIVERY_PUBLIC_ORIGIN=

# --- Viewer ---
# API base URL for SSR pages (viewer → API).
# Example: http://localhost:3000/api/v1
API_BASE=

# --- Ingestion ---
DRAFTS_DIR=                   # Default: ./drafts

# --- Email (Magic Link Auth) ---
# Set RESEND_API_KEY to enable real email delivery for magic link login.
# Without it, production still starts but magic link login is disabled.
# In development, magic links are logged to console.
RESEND_API_KEY=               # Optional Resend API key for sending emails
EMAIL_FROM=                   # Optional sender. Default: Manga CMS <noreply@example.com>

# --- App ---
# Public-facing URL for magic link verify URLs.
# Example: https://yourapp.com/api/v1
APP_URL=

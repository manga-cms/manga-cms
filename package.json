{
  "name": "manga-cms",
  "private": true,
  "description": "Open source infrastructure for publishing structured manga on the web.",
  "license": "Apache-2.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "oxlint scripts --deny-warnings && turbo run lint",
    "check:docs": "node scripts/check-doc-links.mjs",
    "test:compose-safety": "node scripts/test-compose-safety.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "test:content-validation": "node scripts/test-validate-content.mjs"
  },
  "devDependencies": {
    "oxlint": "^1.69.0",
    "turbo": "^2.1.0"
  },
  "packageManager": "pnpm@9.5.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
